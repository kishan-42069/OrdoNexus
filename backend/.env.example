# ─────────────────────────────────────────
#  OrdoNexus — Environment Variables
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://ordonexus:ordonexus@localhost:5432/ordonexus

# For Supabase:
# DATABASE_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres

# For Neon (serverless):
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/ordonexus?sslmode=require

# For Railway:
# DATABASE_URL=postgresql://postgres:<pass>@containers-us-west-xxx.railway.app:6543/railway

# App settings
APP_ENV=production        # production | staging | development
DEBUG_SQL=false           # set true to log all SQL queries
SECRET_KEY=change-me-in-production
